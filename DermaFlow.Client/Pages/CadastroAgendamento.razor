@page "/agendamentos/novo"
@using DermaFlow.Shared.DTOs
@using DermaFlow.Shared.Enums
@inject HttpClient Http
@inject NotificationService NotificationService

<RadzenContent Container="main">
    <RadzenText TextStyle="TextStyle.H4" TagName="TagName.H1" Class="rz-mb-4">
        Gestão de Agendamentos
    </RadzenText>

    <div class="row">
        @* COLUNA DA ESQUERDA: FORMULÁRIO DE CADASTRO *@
        <div class="col-md-4">
            <RadzenTemplateForm TItem="AgendamentoRequestDTO" Data="@model" Submit="@OnSubmit">
                <RadzenCard>
                    <RadzenText TextStyle="TextStyle.H6" Class="rz-mb-4">Novo Cadastro</RadzenText>
                    <RadzenStack Gap="1rem">
                        <div>
                            <RadzenLabel Text="Paciente" Component="Paciente" />
                            <RadzenDropDown @bind-Value="@model.PacienteId" Data="@pacientes" 
                                            TextProperty="Nome" ValueProperty="Id" 
                                            Placeholder="Selecione..." Style="width: 100%" Name="Paciente" 
                                            AllowFiltering="true" />
                            <RadzenRequiredValidator Component="Paciente" Text="Obrigatório" DefaultValue="Guid.Empty" />
                        </div>

                        <div>
                            <RadzenLabel Text="Procedimentos" Component="Procedimentos" />
                            <RadzenDropDown @bind-Value="@model.ProcedimentoIds" Data="@procedimentos" 
                                            Multiple="true" Chips="true" 
                                            TextProperty="Nome" ValueProperty="Id" 
                                            Placeholder="Selecione..." Style="width: 100%" Name="Procedimentos" />
                        </div>

                        <div>
                            <RadzenLabel Text="Data e Hora" Component="DataHora" />
                            <RadzenDatePicker @bind-Value="@model.DataHora" ShowTime="true" 
                                              DateFormat="dd/MM/yyyy HH:mm" Style="width: 100%" Name="DataHora" />
                        </div>

                        <RadzenButton ButtonType="ButtonType.Submit" Text="Salvar Agendamento" 
                                      Icon="save" ButtonStyle="ButtonStyle.Primary" Class="rz-mt-2" />
                    </RadzenStack>
                </RadzenCard>
            </RadzenTemplateForm>
        </div>

        @* COLUNA DA DIREITA: GRID COM OS ÚLTIMOS AGENDAMENTOS *@
        <div class="col-md-8">
            <RadzenCard Style="height: 100%">
                <RadzenText TextStyle="TextStyle.H6" Class="rz-mb-4">Agendamentos Recentemente Cadastrados</RadzenText>
                
                <RadzenDataGrid Data="@agendamentosRecentes" TItem="AgendamentoResponseDTO" 
                                AllowPaging="true" PageSize="8" Density="Density.Compact"
                                AllowSorting="true" EmptyText="Nenhum agendamento encontrado.">
                    <Columns>
                        <RadzenDataGridColumn TItem="AgendamentoResponseDTO" Property="DataHora" Title="Data/Hora" Width="150px">
                            <Template Context="data">
                                @data.DataHora.ToString("dd/MM HH:mm")
                            </Template>
                        </RadzenDataGridColumn>
                        <RadzenDataGridColumn TItem="AgendamentoResponseDTO" Property="PacienteNome" Title="Paciente" />
                        <RadzenDataGridColumn TItem="AgendamentoResponseDTO" Title="Status" Width="100px">
                            <Template Context="data">
                                <RadzenBadge Text="Agendado" BadgeStyle="BadgeStyle.Success" />
                            </Template>
                        </RadzenDataGridColumn>
                    </Columns>
                </RadzenDataGrid>
            </RadzenCard>
        </div>
    </div>
</RadzenContent>

@code {
    AgendamentoRequestDTO model = new() { DataHora = DateTime.Now };
    List<PacienteDTO> pacientes = new();
    List<ProcedimentoDTO> procedimentos = new();
    List<AgendamentoResponseDTO> agendamentosRecentes = new();

    protected override async Task OnInitializedAsync()
    {
        await CarregarDados();
    }

    async Task CarregarDados()
    {
        try 
        {
            pacientes = await Http.GetFromJsonAsync<List<PacienteDTO>>("v1/pacientes") ?? new();
            procedimentos = await Http.GetFromJsonAsync<List<ProcedimentoDTO>>("v1/procedimentos") ?? new();
            agendamentosRecentes = await Http.GetFromJsonAsync<List<AgendamentoResponseDTO>>("v1/agendamentos") ?? new();
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erro de Conexão", ex.Message);
        }
    }

    async Task OnSubmit()
    {
        try 
        {
            model.ClinicId = Guid.Empty; // Ajustar conforme sua lógica de Clínica

            var response = await Http.PostAsJsonAsync("v1/agendamentos", model);

            if (response.IsSuccessStatusCode)
            {
                NotificationService.Notify(NotificationSeverity.Success, "Sucesso", "Agendamento realizado!");
                
                // Limpa o formulário e recarrega o Grid lateral
                model = new() { DataHora = DateTime.Now };
                await CarregarDados(); 
            }
            else
            {
                NotificationService.Notify(NotificationSeverity.Error, "Erro", "Falha ao salvar.");
            }
        }
        catch (Exception ex)
        {
            NotificationService.Notify(NotificationSeverity.Error, "Erro Crítico", ex.Message);
        }
    }
}